# Android release signing — TEMPLATE (safe to commit; holds no secrets).
#
# To sign a release build:
#   1. Generate an upload keystore (do this ONCE, keep it forever — losing it
#      means you can never update the app on Play):
#        keytool -genkey -v -keystore gimme-upload.keystore \
#          -alias gimme-upload -keyalg RSA -keysize 2048 -validity 10000
#   2. Put gimme-upload.keystore somewhere safe (e.g. android/app/) and back it
#      up in your password manager along with BOTH passwords.
#   3. Copy this file to  android/keystore.properties  and fill in the real values.
#      That real file is gitignored and must NEVER be committed.
#
# storeFile is resolved relative to android/app/ (or use an absolute path).

storeFile=gimme-upload.keystore
storePassword=CHANGE_ME
keyAlias=gimme-upload
keyPassword=CHANGE_ME

# Alternatively, skip this file and set env vars instead:
#   GIMME_KEYSTORE, GIMME_KEYSTORE_PASSWORD, GIMME_KEY_ALIAS, GIMME_KEY_PASSWORD
